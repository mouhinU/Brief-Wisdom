# ============================================
# Brief-Wisdom 环境变量配置
# ============================================
# 复制此文件为 .env 并修改对应值
# cp .env.example .env

# MySQL 配置
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3306

# Redis 配置
REDIS_PASSWORD=123456
REDIS_PORT=6379

# 应用配置
APP_PORT=8090
SPRING_PROFILES_ACTIVE=dev

# CORS 允许的域名（生产环境必填，逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:8090,http://localhost:3000

# 知识库 Markdown 导入根目录（可选，默认 user.dir）
KNOWLEDGE_IMPORT_BASE_DIR=

# AI 提供商 API Key（至少配置一个）
AI_API_KEY=your-dashscope-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# OAuth 配置（可选）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
